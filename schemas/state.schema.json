{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Teach Me State",
  "type": "object",
  "required": [
    "version",
    "skill",
    "title",
    "slug",
    "createdAt",
    "updatedAt",
    "phase",
    "learner",
    "teachingPreferences",
    "current",
    "progress",
    "resumeSummary"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "skill": { "const": "teach-me" },
    "title": { "type": "string" },
    "slug": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "phase": {
      "type": "string",
      "enum": ["intake", "collecting-resources", "scope-confirmation", "planning", "approval", "learning", "paused", "completed"]
    },
    "learner": {
      "type": "object",
      "properties": {
        "goal": { "type": "string" },
        "scopeType": { "type": "string", "enum": ["point", "course", "unknown", "custom"] },
        "desiredDepth": { "type": "string" },
        "knownTopics": { "type": "array", "items": { "type": "string" } },
        "weakTopics": { "type": "array", "items": { "type": "string" } },
        "timeBudget": {
          "type": "object",
          "properties": {
            "total": { "type": "string" },
            "perSession": { "type": "string" },
            "deadline": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "teachingPreferences": {
      "type": "object",
      "required": ["language"],
      "properties": {
        "language": { "type": "string" },
        "coachName": { "type": "string", "default": "coach" },
        "explanationLength": { "type": "string", "enum": ["short", "medium", "long", "adaptive"] },
        "pace": { "type": "string", "enum": ["slow", "normal", "fast", "adaptive"] },
        "exampleStyle": { "type": "string" },
        "visualization": { "type": "string", "enum": ["none", "auto", "frequent", "html-when-useful", "html-on-request"] },
        "exerciseFrequency": { "type": "string", "enum": ["none", "light", "normal", "heavy", "adaptive"] },
        "exerciseDifficulty": { "type": "string", "enum": ["easy", "medium", "hard", "adaptive"] },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "title": { "type": "string" },
          "locator": { "type": "string" },
          "summary": { "type": "string" },
          "usedFor": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "current": {
      "type": "object",
      "properties": {
        "chapterId": { "type": "string" },
        "itemId": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "progress": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "display"],
        "properties": {
          "id": { "type": "string" },
          "chapterId": { "type": "string" },
          "title": { "type": "string" },
          "objective": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "known", "skipped", "needs-review"] },
          "display": { "type": "string", "enum": ["[ ]", "[-]", "[x]"] },
          "note": { "type": "string" },
          "resources": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "visuals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "path": { "type": "string" },
              "relatedItemId": { "type": "string" },
              "summary": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "resumeSummary": { "type": "string" }
  },
  "additionalProperties": true
}
